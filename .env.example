# This is an example .env file.
# To use it, create a new file named '.env' in the project root,
# copy this content into it, and replace the placeholder values
# with your actual API keys and configuration.
# The .env file should NEVER be committed to version control.

# --- Core AI and Data APIs ---
# Found on your OpenAI account dashboard. Used for content generation and analysis.
OPENAI_API_KEY="your_openai_api_key_here"

# Found in your Apollo.io account settings. Used for prospect search and response tracking.
APOLLO_API_KEY="your_apollo_api_key_here"

# Found in your Clay.com account settings. Used for prospect search.
CLAY_API_KEY="your_clay_api_key_here"

# Found in your Abstract account settings. Used for data enrichment.
ABSTRACT_API_KEY="your_Abstract_key_here"


# --- Email and Reporting ---
# Found in your SendGrid account settings. Used for sending outreach emails.
SENDGRID_API_KEY="your_sendgrid_api_key_here"

# The unique ID of the Google Sheet for the Feedback Trainer agent.
# You can find this in the URL of your sheet: docs.google.com/spreadsheets/d/THIS_IS_THE_SHEET_ID/edit
SHEET_ID="your_google_sheet_id_here"
# Add this line to your file
SENDGRID_FROM_EMAIL="your.verified@gmail.com"